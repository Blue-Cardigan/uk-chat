{
  "name": "chatgb",
  "private": true,
  "version": "0.1.0",
  "description": "ChatGB Application",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "wrangler pages dev dist --port 3000 --compatibility-date 2026-04-01 --compatibility-flags nodejs_compat",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test:unit": "tsx --test src/lib/viz-data-parser.test.ts api/_lib/council/*.test.ts api/_lib/mcp-token-recovery.test.ts",
    "user:add": "tsx scripts/add-user.ts",
    "prepare": "husky || true"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/react": "^3.0.143",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@supabase/supabase-js": "^2.100.1",
    "@types/d3-scale": "^4.0.9",
    "ai": "^6.0.141",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "hono": "^4.12.14",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.83.0"
  }
}
